# =============================================================================
# MyVoice (밤토리) - Environment Variables
# Copy this file to .env and fill in actual values
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME=MyVoice API
APP_ENV=development          # development | staging | production
DEBUG=true                   # false in production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# -----------------------------------------------------------------------------
# Database (PostgreSQL + asyncpg)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://myvoice:myvoice_dev@localhost:5432/myvoice

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production   # MUST change in production (validated)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440         # 24 hours

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:8000       # Backend API base URL
FRONTEND_URL=http://127.0.0.1:5173      # Frontend URL (for OAuth redirects, emails)

# -----------------------------------------------------------------------------
# OpenAI (HTTP fallback mode - STT/GPT/TTS)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-api-key-here

# -----------------------------------------------------------------------------
# Voice Mode
# -----------------------------------------------------------------------------
VOICE_MODE=http              # "http" (OpenAI Whisper+GPT+TTS) | "websocket" (Azure Realtime)

# -----------------------------------------------------------------------------
# Azure OpenAI Realtime API (required when VOICE_MODE=websocket)
# -----------------------------------------------------------------------------
AZURE_REALTIME_API_KEY=
AZURE_REALTIME_ENDPOINT=     # e.g. https://your-resource.openai.azure.com
AZURE_REALTIME_API_VERSION=2025-04-01-preview
AZURE_REALTIME_DEPLOYMENT=gpt-4o-realtime-preview

# -----------------------------------------------------------------------------
# Azure Whisper STT (optional - falls back to Realtime settings if empty)
# -----------------------------------------------------------------------------
AZURE_WHISPER_API_KEY=       # falls back to AZURE_REALTIME_API_KEY
AZURE_WHISPER_ENDPOINT=      # falls back to AZURE_REALTIME_ENDPOINT
AZURE_WHISPER_API_VERSION=2024-06-01
AZURE_WHISPER_DEPLOYMENT=whisper

# -----------------------------------------------------------------------------
# Email Service (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=no-reply@bamtory.com
EMAIL_FROM_NAME=밤토리

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Kakao OAuth
# -----------------------------------------------------------------------------
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# -----------------------------------------------------------------------------
# Apple Sign In
# -----------------------------------------------------------------------------
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----
APPLE_BUNDLE_ID=com.yourdomain.bamtory
