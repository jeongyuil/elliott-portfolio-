---
import en from '../i18n/en.json';
import ko from '../i18n/ko.json';
const contact = en.contact;
const contactKo = ko.contact;
---
<section id="contact" class="relative py-28 px-6">
  <div class="absolute inset-0 grid-bg opacity-50"></div>
  <div class="absolute top-0 left-0 right-0 section-divider"></div>

  <!-- Background glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute w-96 h-96 rounded-full bg-primary/5 blur-3xl top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  </div>

  <div class="relative max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text-bright mb-4 fade-up heading-underline mx-auto w-fit"
        data-en={contact.heading} data-ko={contactKo.heading}>
      {contact.heading}
    </h2>
    <p class="text-xl md:text-2xl font-medium text-text-bright text-center mb-4 fade-up"
       data-en={contact.tagline} data-ko={contactKo.tagline}>
      {contact.tagline}
    </p>

    <p class="text-text-muted text-lg mb-12 leading-relaxed fade-up"
       data-en={contact.desc} data-ko={contactKo.desc}>
      {contact.desc}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center fade-up">
      <!-- Email -->
      <a href="mailto:jeongyuil@gmail.com" class="flex items-center gap-3 px-6 py-4 bg-surface rounded-2xl border border-border/50 hover:border-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-primary/10 group card-shine hover:-translate-y-0.5">
        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
        <div class="text-left">
          <span class="text-text-bright font-medium block" data-en={contact.email} data-ko={contactKo.email}>{contact.email}</span>
          <span class="text-text-muted text-xs">jeongyuil@gmail.com</span>
        </div>
      </a>

      <!-- LinkedIn -->
      <a href="https://www.linkedin.com/in/yuil-jeong/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-4 bg-surface rounded-2xl border border-border/50 hover:border-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-primary/10 group card-shine hover:-translate-y-0.5">
        <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-500/20 transition-colors">
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div class="text-left">
          <span class="text-text-bright font-medium block" data-en={contact.linkedin} data-ko={contactKo.linkedin}>{contact.linkedin}</span>
          <span class="text-text-muted text-xs">yuil-jeong</span>
        </div>
      </a>

      <!-- GitHub -->
      <a href="https://github.com/jeongyuil" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-4 bg-surface rounded-2xl border border-border/50 hover:border-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-primary/10 group card-shine hover:-translate-y-0.5">
        <div class="w-10 h-10 rounded-xl bg-surface-light flex items-center justify-center group-hover:bg-border/30 transition-colors">
          <svg class="w-5 h-5 text-text-bright" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div class="text-left">
          <span class="text-text-bright font-medium block" data-en={contact.github} data-ko={contactKo.github}>{contact.github}</span>
          <span class="text-text-muted text-xs">jeongyuil</span>
        </div>
      </a>
    </div>
  </div>
</section>
