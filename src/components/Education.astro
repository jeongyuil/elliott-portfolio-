---
import en from '../i18n/en.json';
import ko from '../i18n/ko.json';
const education = en.education;
const educationKo = ko.education;

const schoolIcons = [
  '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>',
  '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"></path></svg>',
];

const gradientColors = [
  'from-accent/20 to-accent/5 border-accent/30',
  'from-primary/20 to-primary/5 border-primary/30',
];

const iconBgColors = [
  'bg-accent/10 text-accent',
  'bg-primary/10 text-primary',
];
---
<section id="education" class="relative py-28 px-6">
  <div class="absolute inset-0 grid-bg opacity-50"></div>
  <div class="absolute top-0 left-0 right-0 section-divider"></div>

  <div class="relative max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-text-bright mb-4 text-center fade-up heading-underline mx-auto w-fit"
        data-en={education.heading} data-ko={educationKo.heading}>
      {education.heading}
    </h2>
    <p class="text-text-muted text-center mb-16 fade-up" data-en="The foundation of everything" data-ko="모든 것의 기반">The foundation of everything</p>

    <div class="grid md:grid-cols-2 gap-6">
      {education.items.map((item, i) => (
        <div class={`fade-up rounded-2xl p-8 border bg-gradient-to-br ${gradientColors[i]} card-shine hover:shadow-lg transition-all duration-300`}>
          <div class="flex items-center gap-4 mb-4">
            <div class={`w-12 h-12 rounded-xl ${iconBgColors[i]} flex items-center justify-center`}>
              <Fragment set:html={schoolIcons[i]} />
            </div>
            <div>
              <span class="text-primary text-sm font-medium"
                    data-en={item.period} data-ko={educationKo.items[i].period}>
                {item.period}
              </span>
            </div>
          </div>

          <h3 class="text-xl font-semibold text-text-bright"
              data-en={item.degree} data-ko={educationKo.items[i].degree}>
            {item.degree}
          </h3>
          <p class="text-accent font-medium mt-1"
             data-en={item.field} data-ko={educationKo.items[i].field}>
            {item.field}
          </p>
          <p class="text-text-muted text-sm mt-1"
             data-en={item.school} data-ko={educationKo.items[i].school}>
            {item.school}
          </p>

          <div class="mt-4 pt-4 border-t border-border/20">
            <p class="text-text-muted text-sm leading-relaxed"
               data-en={item.desc} data-ko={educationKo.items[i].desc}>
              {item.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
