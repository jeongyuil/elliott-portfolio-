---
import en from '../i18n/en.json';
import ko from '../i18n/ko.json';
const hero = en.hero;
const heroKo = ko.hero;
---
<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background layers -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#050510] via-bg to-[#0a0a1a] z-0"></div>
  
  <!-- Interactive Quantum Canvas -->
  <canvas id="quantum-canvas" class="absolute inset-0 w-full h-full z-0 opacity-90" aria-hidden="true"></canvas>

  <!-- Radial gradients overlays -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(99,102,241,0.15)_0%,_transparent_50%)] pointer-events-none z-0"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(139,92,246,0.1)_0%,_transparent_50%)] pointer-events-none z-0"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

      <!-- Left: Text content -->
      <div class="flex-1 text-center lg:text-left order-2 lg:order-1">
        <!-- Greeting badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border/50 bg-surface/50 backdrop-blur-sm mb-8 fade-up">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-text-muted text-sm" data-en="Available for opportunities" data-ko="새로운 기회를 환영합니다">Available for opportunities</span>
        </div>

        <!-- Name with gradient -->
        <h1 class="text-5xl md:text-7xl font-bold mb-3 fade-up">
          <span class="gradient-text" data-en={hero.name} data-ko={heroKo.name}>{hero.name}</span>
        </h1>

        <!-- Nickname -->
        <p class="text-2xl md:text-3xl font-light text-primary/80 mb-8 fade-up">
          (<span data-en={hero.nickname} data-ko={heroKo.nickname}>{hero.nickname}</span>)
        </p>

        <!-- Title with border -->
        <div class="inline-block mb-8 fade-up">
          <h2 class="text-lg md:text-xl font-medium text-text px-6 py-3 rounded-2xl border border-border/30 bg-surface/30 backdrop-blur-sm"
              data-en={hero.title} data-ko={heroKo.title}>
            {hero.title}
          </h2>
        </div>

        <!-- Subtitle -->
        <p class="text-text-muted text-lg md:text-xl max-w-2xl mx-auto lg:mx-0 mb-10 leading-relaxed fade-up"
           data-en={hero.subtitle} data-ko={heroKo.subtitle}>
          {hero.subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start fade-up">
          <a href="#contact" class="group relative px-8 py-3.5 bg-primary hover:bg-primary-light text-white font-medium rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 overflow-hidden">
            <span class="relative z-10 flex items-center justify-center gap-2">
              <span data-en={hero.cta_contact} data-ko={heroKo.cta_contact}>{hero.cta_contact}</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </a>
          <a href="/resume" target="_blank" class="group px-8 py-3.5 border border-border hover:border-primary/50 text-text-bright font-medium rounded-full transition-all duration-300 hover:text-primary hover:bg-primary/5">
            <span class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <span data-en={hero.cta_resume} data-ko={heroKo.cta_resume}>{hero.cta_resume}</span>
            </span>
          </a>
        </div>
      </div>

      <!-- Right: Profile photo -->
      <div class="flex-shrink-0 order-1 lg:order-2 fade-up w-full lg:w-auto">
        <div class="relative max-w-md mx-auto lg:mx-0">
          <!-- Glow behind photo -->
          <div class="absolute -inset-4 bg-gradient-to-br from-primary/20 via-accent/10 to-primary/20 rounded-3xl blur-2xl"></div>
          <!-- Photo container -->
          <div class="relative rounded-3xl overflow-hidden border-2 border-border/30 shadow-2xl shadow-primary/10">
            <img src="/profile.jpeg" alt="Yuil Jeong (Elliott) presenting at Seoul National University Winter Statistics Conference" class="w-full h-auto object-cover" loading="eager" />
          </div>
          <!-- Caption -->
          <p class="text-center text-text-muted/60 text-xs mt-3" data-en="SNU Winter Statistics Conference" data-ko="서울대학교 겨울 통계학회 발표">SNU Winter Statistics Conference</p>
          <!-- Decorative corner accents -->
          <div class="absolute -top-2 -right-2 w-6 h-6 border-t-2 border-r-2 border-primary/40 rounded-tr-lg"></div>
          <div class="absolute -bottom-2 -left-2 w-6 h-6 border-b-2 border-l-2 border-accent/40 rounded-bl-lg"></div>
        </div>
      </div>

    </div>

    <!-- Quick stats row -->
    <div class="mt-16 flex flex-wrap justify-center gap-8 md:gap-12 fade-up">
      <div class="text-center">
        <p class="text-2xl md:text-3xl font-bold text-text-bright">14+</p>
        <p class="text-xs text-text-muted mt-1" data-en="Years Experience" data-ko="년 경력">Years Experience</p>
      </div>
      <div class="w-px h-12 bg-border/50 hidden sm:block"></div>
      <div class="text-center">
        <p class="text-2xl md:text-3xl font-bold text-text-bright">Disney+</p>
        <p class="text-xs text-text-muted mt-1" data-en="& EA Global" data-ko="& EA 글로벌">& EA Global</p>
      </div>
      <div class="w-px h-12 bg-border/50 hidden sm:block"></div>
      <div class="text-center">
        <p class="text-2xl md:text-3xl font-bold text-text-bright">$1B+</p>
        <p class="text-xs text-text-muted mt-1" data-en="Strategy Impact" data-ko="전략 임팩트">Strategy Impact</p>
      </div>
      <div class="w-px h-12 bg-border/50 hidden sm:block"></div>
      <div class="text-center">
        <p class="text-2xl md:text-3xl font-bold text-text-bright">CEO</p>
        <p class="text-xs text-text-muted mt-1" data-en="JNJ Corporation" data-ko="JNJ Corporation">JNJ Corporation</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex-col items-center gap-2 hidden md:flex z-20">
    <span class="text-text-muted text-xs tracking-widest uppercase" data-en="Scroll" data-ko="스크롤">Scroll</span>
    <div class="w-5 h-8 rounded-full border-2 border-text-muted/30 flex justify-center pt-1.5">
      <div class="w-1 h-2 rounded-full bg-text-muted/50 animate-bounce"></div>
    </div>
  </div>
</section>

<script>
  // Dynamic Canvas Background Engine
  const canvas = document.getElementById('quantum-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let width = (canvas.width = window.innerWidth);
    let height = (canvas.height = window.innerHeight);
    let particles: Particle[] = [];
    const minDistance = 180;
    
    // Smooth mouse easing
    const mouse = { x: width / 2, y: height / 2, tx: width / 2, ty: height / 2, radius: 250, isActive: false };
    
    window.addEventListener('resize', () => {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
      initParticles();
    });
    
    // Keep tracking mouse over the whole document for smoother entry/exit
    document.addEventListener('mousemove', (e) => {
      mouse.tx = e.clientX;
      mouse.ty = e.clientY;
      mouse.isActive = true;
    });
    
    document.addEventListener('mouseleave', () => {
      mouse.isActive = false;
    });

    class Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      radius: number;
      color: string;
      baseX: number;
      baseY: number;
      glow: boolean;
      
      constructor() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.baseX = this.x;
        this.baseY = this.y;
        this.vx = (Math.random() - 0.5) * 0.6; // Slightly faster for dynamic feel
        this.vy = (Math.random() - 0.5) * 0.6;
        this.radius = Math.random() * 2 + 0.5;
        this.glow = Math.random() > 0.9;
        
        const colors = [
          'rgba(99, 102, 241, 0.9)',   // Primary
          'rgba(129, 140, 248, 0.8)',  // Primary Light
          'rgba(139, 92, 246, 0.8)',   // Accent
          'rgba(167, 139, 250, 0.6)',  // Accent Light
          'rgba(255, 255, 255, 0.4)'   // Distant stars
        ];
        this.color = colors[Math.floor(Math.random() * colors.length)];
      }

      draw() {
        if (!ctx) return;
        if (this.glow) {
            // Replaced shadowBlur with a secondary, lower-opacity arc for a "glow" effect without the performance hit
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.radius * 2.5, 0, Math.PI * 2);
            ctx.fillStyle = this.color.replace(/[\d.]+\)$/g, '0.15)'); // change opacity
            ctx.fill();
            ctx.closePath();
        }
        
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = this.color;
        
        ctx.fill();
        ctx.closePath();
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;

        // Wrap around smoothly
        if (this.x < 0) this.x = width;
        if (this.x > width) this.x = 0;
        if (this.y < 0) this.y = height;
        if (this.y > height) this.y = 0;

        // Mouse interaction (quantum repulsion with easing)
        if (mouse.isActive) {
          let dx = mouse.x - this.x;
          let dy = mouse.y - this.y;
          let distance = Math.sqrt(dx * dx + dy * dy);
          
          if (distance < mouse.radius) {
            const forceDirectionX = dx / distance;
            const forceDirectionY = dy / distance;
            // Easing the force to be strong initially then fade out
            const force = (mouse.radius - distance) / mouse.radius;
            // Particle repels slightly
            this.x -= forceDirectionX * force * 1.5;
            this.y -= forceDirectionY * force * 1.5;
          }
        }
      }
    }

    function initParticles() {
      particles = [];
      const particleDensity = window.innerWidth < 768 ? 8000 : 12000;
      // capped max particles for performance
      const numParticles = Math.min(Math.floor((width * height) / particleDensity), 150);
      for (let i = 0; i < numParticles; i++) {
        particles.push(new Particle());
      }
    }

    let animationId: number;
    let isVisible = true;

    function animate() {
      if (!ctx || !isVisible) return;
      
      // Interpolate mouse movement for smoothness
      mouse.x += (mouse.tx - mouse.x) * 0.1;
      mouse.y += (mouse.ty - mouse.y) * 0.1;

      // Dark trail effect instead of clearRect
      ctx.fillStyle = 'rgba(10, 10, 15, 0.4)'; // Slightly faster fade
      ctx.fillRect(0, 0, width, height);
      
      for (let i = 0; i < particles.length; i++) {
        particles[i].update();
        particles[i].draw();

        // Check distance for quantum entanglement lines
        for (let j = i; j < particles.length; j++) {
          let dx = particles[i].x - particles[j].x;
          let dy = particles[i].y - particles[j].y;
          let distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < minDistance) {
            ctx.beginPath();
            // Network lines color matching the global theme
            ctx.strokeStyle = `rgba(139, 92, 246, ${0.15 - (distance / minDistance) * 0.15})`; 
            ctx.lineWidth = 0.6;
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
            ctx.closePath();
          }
        }
        
        // Connect to mouse to form an interactive web
        if (mouse.isActive) {
           let dx = particles[i].x - mouse.x;
           let dy = particles[i].y - mouse.y;
           let distance = Math.sqrt(dx * dx + dy * dy);
           if (distance < mouse.radius * 0.8) {
              ctx.beginPath();
              ctx.strokeStyle = `rgba(99, 102, 241, ${0.25 - distance / (mouse.radius*0.8) * 0.25})`; 
              ctx.lineWidth = 1;
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(mouse.x, mouse.y);
              ctx.stroke();
              ctx.closePath();
           }
        }
      }
      animationId = requestAnimationFrame(animate);
    }

    // Optimization: Only animate when the hero section is visible
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!isVisible) {
              isVisible = true;
              animate();
            }
          } else {
            isVisible = false;
            if (animationId) cancelAnimationFrame(animationId);
          }
        });
      },
      { threshold: 0 }
    );
    
    const heroSection = document.getElementById('hero');
    if (heroSection) {
      observer.observe(heroSection);
    }

    initParticles();
    animate();
  }
</script>
