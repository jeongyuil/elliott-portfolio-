---
import en from '../i18n/en.json';
import ko from '../i18n/ko.json';
const projects = en.projects;
const projectsKo = ko.projects;

const statusColors: Record<string, string> = {
  'Deployed': 'bg-green-500/20 text-green-400 border-green-500/30',
  'In Development': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  'In Progress': 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  'Completed': 'bg-primary/20 text-primary-light border-primary/30',
  '배포 완료': 'bg-green-500/20 text-green-400 border-green-500/30',
  '개발 중': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  '진행 중': 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  '완료': 'bg-primary/20 text-primary-light border-primary/30',
};

const projectGradients = [
  'from-green-500/10 via-transparent to-transparent',
  'from-blue-500/10 via-transparent to-transparent',
  'from-yellow-500/10 via-transparent to-transparent',
  'from-primary/10 via-transparent to-transparent',
];

const projectIcons = [
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>',
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>',
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>',
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>',
];

const iconColors = ['text-green-400', 'text-blue-400', 'text-yellow-400', 'text-primary-light'];
---
<section id="projects" class="relative py-28 px-6">
  <div class="absolute inset-0 grid-bg opacity-50"></div>
  <div class="absolute top-0 left-0 right-0 section-divider"></div>

  <div class="relative max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-text-bright mb-4 text-center fade-up heading-underline mx-auto w-fit"
        data-en={projects.heading} data-ko={projectsKo.heading}>
      {projects.heading}
    </h2>
    <p class="text-text-muted text-center mb-16 fade-up" data-en="What I'm building" data-ko="만들고 있는 것들">What I'm building</p>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.items.map((item, i) => {
        const link = (item as any).link;
        const Wrapper = link ? 'a' : 'div';
        return (
          <Wrapper
            href={link || undefined}
            target={link ? '_blank' : undefined}
            rel={link ? 'noopener noreferrer' : undefined}
            class={`scale-up group bg-surface rounded-2xl border border-border/50 hover:border-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-1 block overflow-hidden card-shine`}
          >
            {/* Gradient top bar */}
            <div class={`h-1 bg-gradient-to-r ${projectGradients[i]}`}></div>

            <div class="p-6">
              <div class="flex items-start justify-between mb-4">
                <div class={`w-14 h-14 rounded-2xl bg-surface-light flex items-center justify-center ${iconColors[i]} group-hover:scale-110 transition-transform duration-300`}>
                  <Fragment set:html={projectIcons[i]} />
                </div>
                <span class={`text-xs px-3 py-1 rounded-full font-medium border ${statusColors[item.status] || 'bg-surface-light text-text-muted border-border'}`}
                      data-en={item.status} data-ko={projectsKo.items[i].status}>
                  {item.status}
                </span>
              </div>

              <h3 class="text-xl font-semibold text-text-bright mb-2 group-hover:text-primary transition-colors flex items-center gap-2">
                {item.title}
                {link && (
                  <svg class="w-4 h-4 text-text-muted group-hover:text-primary group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                )}
              </h3>

              <p class="text-text-muted text-sm leading-relaxed mb-5"
                 data-en={item.desc} data-ko={projectsKo.items[i].desc}>
                {item.desc}
              </p>

              <div class="flex flex-wrap gap-2">
                {item.tags.map((tag, j) => (
                  <span class="text-xs px-2.5 py-1 rounded-full bg-surface-light text-text-muted border border-border/50 group-hover:border-border transition-colors"
                        data-en={tag} data-ko={projectsKo.items[i].tags[j]}>
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </Wrapper>
        );
      })}
    </div>
  </div>
</section>
